<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="Jl/6eOCXY2[?^~N[aZ}n" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="0:?N@*hab1GYA=R@EHx{"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace MCarBot {" line1="    //% block = &quot;RGB Led Left On $red $green $blue&quot;" line2="    //% red.defl=255" line3="    //% red.min=0 red.max=255" line4="    //% green.defl=255" line5="    //% green.min=0 green.max=255" line6="    //% blue.defl=255" line7="    //% blue.min=0 blue.max=255" line8="    export function RgbLeftLedOn(red: number, green: number, blue: number) {" line9="        sendI2cWriteCommand(13, 4, red, green, blue, 0, 0, 0);" line10="    }" line11="    //% block = &quot;RGB Led Left Off&quot;" line12="    export function RgbLeftLedOff() {" line13="        sendI2cWriteCommand(14, 4, 0, 0, 0, 0, 0, 0);" line14="    }" line15="    //% block = &quot;RGB Led Right On $red $green $blue&quot;" line16="    //% red.defl=255" line17="    //% red.min=0 red.max=255" line18="    //% green.defl=255" line19="    //% green.min=0 green.max=255" line20="    //% blue.defl=255" line21="    //% blue.min=0 blue.max=255" line22="    export function RgbRightLedOn(red: number, green: number, blue: number) {" line23="        sendI2cWriteCommand(15, 4, red, green, blue, 0, 0, 0);" line24="    }" line25="    //% block = &quot;RGB Led Right Off&quot;" line26="    export function RgbRightLedOff() {" line27="        sendI2cWriteCommand(16, 4, 0, 0, 0, 0, 0, 0);" line28="    }" line29="    //% block = &quot;MCarbot Init&quot;" line30="    export function McarBotInit() {" line31="        sendI2cWriteCommand(16, 4, 0, 0, 0, 0, 0, 0);" line32="    }" line33="    //% block = &quot;Line Follower Sensors On&quot;" line34="    export function LfSensorsOn() {" line35="        sendI2cWriteCommand(24, 4, 0, 0, 0, 0, 0, 0);" line36="    }" line37="    //% block = &quot;Line Follower Sensors Off&quot;" line38="    export function LfSensorsOff() {" line39="        sendI2cWriteCommand(25, 4, 0, 0, 0, 0, 0, 0);" line40="    }" line41="    // note that Caml casing yields lower case" line42="    // block text with spaces" line43="    export function getRpAddress() {" line44="        let rp_address = 0x13;" line45="        return rp_address;" line46="    }" line47="    function sendI2cWriteCommand(commandId: number, peripheralId: number, arg1: number, arg2: number, arg3: number, arg4: number, arg5: number, arg6: number) {" line48="        let writeCommandBuffer = pins.createBuffer(9);" line49="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 0, commandId);" line50="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 1, peripheralId);" line51="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 2, 1);" line52="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 3, arg1);" line53="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 4, arg2);" line54="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 5, arg3);" line55="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 6, arg4);" line56="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 7, arg5);" line57="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 8, arg6);" line58="        pins.i2cWriteBuffer(getRpAddress(), writeCommandBuffer, false);" line59="    }" line60="}" numlines="61"></mutation></block></statement></block></xml>