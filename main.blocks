<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="[U+Gc/chVt0|Ol[PJptD" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="32Qs!lNA=Q}hR]KV+1wH"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace MCarBot {" line1="    //% block = &quot;RGB Led Left On $red $green $blue&quot;" line2="    //% red.defl=255" line3="    //% red.min=0 red.max=255" line4="    //% green.defl=255" line5="    //% green.min=0 green.max=255" line6="    //% blue.defl=255" line7="    //% blue.min=0 blue.max=255" line8="    export function RgbLeftLedOn(red: number, green: number, blue: number) {" line9="        sendI2cWriteCommand(13, 4, red, green, blue, 0, 0, 0,0);" line10="    }" line11="    //% block = &quot;RGB Led Left Off&quot;" line12="    export function RgbLeftLedOff() {" line13="        sendI2cWriteCommand(14, 4, 0, 0, 0, 0, 0, 0,0);" line14="    }" line15="    // note that Caml casing yields lower case" line16="    // block text with spaces" line17="" line18="    export function getRpAddress() {" line19="        let rp_address = 0x13;" line20="        return rp_address;" line21="    }" line22="    function sendI2cWriteCommand(commandId: number, peripheralId: number, arg1: number, arg2: number, arg3: number, arg4: number, arg5: number, arg6: number, arg7: number) {" line23="        let writeCommandBuffer = pins.createBuffer(9);" line24="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 0, commandId);" line25="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 1, peripheralId);" line26="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 2, 1);" line27="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 3, arg1);" line28="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 4, arg2);" line29="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 5, arg3);" line30="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 6, arg4);" line31="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 7, arg5);" line32="        writeCommandBuffer.setNumber(NumberFormat.UInt8LE, 8, arg5);" line33="        pins.i2cWriteBuffer(getRpAddress(), writeCommandBuffer, false);" line34="    }" line35="}" numlines="36"></mutation></block></statement></block></xml>